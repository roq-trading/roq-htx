{
  "name": "Flags",
  "type": "flags",
  "values": [
    {
      "name": "exchange",
      "type": "std::string",
      "validator": "roq::core::flags::NonEmpty",
      "default": "huobi",
      "description": "exchange identifier (string)"
    },
    {
      "name": "rest_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "https://api.huobi.pro",
      "description": "REST end-point (URI)"
    },
    {
      "name": "rest_proxy",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "description": "proxy end-point (URI)"
    },
    {
      "name": "rest_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "rest_ping_path",
      "type": "std::string",
      "validator": "roq::core::flags::Path",
      "default": "/v1/common/timestamp",
      "description": "URI path used for REST connection keep-alive messages"
    },
    {
      "name": "rest_request_timeout",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "30s",
      "description": "request: timeout"
    },
    {
      "name": "rest_listen_key_refresh",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "1800s",
      "description": "listen key refresh period"
    },
    {
      "name": "rest_order_recv_window",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5000ms",
      "description": "receive window"
    },
    {
      "name": "rest_cancel_on_disconnect",
      "type": "bool",
      "default": false,
      "description": "cancel orders on disconnect? (bool)"
    },
    {
      "name": "ws_market_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://api.huobi.pro/ws",
      "description": "WebSocket end-point (URI) for market data (excl. incremental MBP)"
    },
    {
      "name": "ws_mbp_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://api.huobi.pro/feed",
      "description": "WebSocket end-point (URI) for MBP"
    },
    {
      "name": "ws_order_uri",
      "type": "roq::io::web::URI",
      "validator": "roq::core::flags::URI",
      "default": "wss://api.huobi.pro/ws/v2",
      "description": "WebSocket end-point (URI) for account and order"
    },
    {
      "name": "ws_ping_freq",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "5s",
      "description": "ping frequency"
    },
    {
      "name": "ws_max_subscriptions_per_stream",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 128,
      "description": "max symbols per connection (count)"
    },
    {
      "name": "ws_request_delay",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "100ms",
      "description": "request delay"
    },
    {
      "name": "ws_mbp_request_max_retries",
      "type": "uint32_t",
      "default": 3,
      "description": "request max retries"
    },
    {
      "name": "request_limit",
      "type": "uint32_t",
      "default": "10",
      "description": "request limit per interval"
    },
    {
      "name": "request_limit_interval",
      "type": "std::chrono::nanoseconds",
      "validator": "roq::core::flags::TimePeriod",
      "default": "1s",
      "description": "request limit monitor interval"
    },
    {
      "name": "encode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 1048576,
      "description": "encode buffer size"
    },
    {
      "name": "decode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 10485760,
      "description": "decode buffer size"
    },
    {
      "name": "mbp_allow_price_inversion",
      "type": "bool",
      "default": false,
      "description": "allow price inversion?"
    }
  ]
}
