{
  "name": "Flags",
  "type": "flags",
  "values": [
    {
      "name": "config_file",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "description": "config file (path)"
    },
    {
      "name": "exchange",
      "type": "std::string",
      "validator": "roq::core::flags::NonEmpty<std::string>",
      "default": "binance",
      "description": "exchange identifier (string)"
    },
    {
      "name": "rest_uri",
      "type": "roq::core::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "https://testnet.binance.com/api/v1",
      "description": "REST end-point (URI)"
    },
    {
      "name": "rest_ping_freq",
      "flag_name": "rest_ping_freq_secs",
      "type": "std::chrono::seconds",
      "validator": "roq::core::flags::Positive<uint32_t>",
      "default": 5,
      "description": "ping frequency (seconds)"
    },
    {
      "name": "rest_ping_path",
      "type": "std::string",
      "validator": "roq::core::flags::Path<std::string>",
      "default": "/api/v3/time",
      "description": "URI path used for REST connection keep-alive messages"
    },
    {
      "name": "rest_request_timeout",
      "flag_name": "rest_request_timeout_secs",
      "type": "std::chrono::seconds",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 30,
      "description": "request: timeout (seconds)"
    },
    {
      "name": "rest_rate_limit_interval",
      "flag_name": "rest_rate_limit_interval_secs",
      "type": "std::chrono::seconds",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 60,
      "description": "rate limit: monitor interval (seconds)"
    },
    {
      "name": "rest_rate_limit_max_requests",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 1200,
      "description": "rate limit: max requests (per interval)"
    },
    {
      "name": "rest_listen_key_refresh",
      "flag_name": "rest_listen_key_refresh_secs",
      "type": "std::chrono::seconds",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 1800,
      "description": "listen key refresh period (seconds)"
    },
    {
      "name": "rest_order_recv_window",
      "flag_name": "rest_order_recv_window_msecs",
      "type": "std::chrono::milliseconds",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 5000,
      "description": "receive window (milliseconds), please refer to Binance documentation!"
    },
    {
      "name": "rest_cancel_on_disconnect",
      "type": "bool",
      "default": false,
      "description": "cancel orders on disconnect? (bool)"
    },
    {
      "name": "ws_uri",
      "type": "roq::core::URI",
      "validator": "roq::core::flags::URI<std::string>",
      "default": "wss://testnet.binance.com/realtime",
      "description": "WebSocket end-point (URI)"
    },
    {
      "name": "ws_ping_freq",
      "flag_name": "ws_ping_freq_secs",
      "type": "std::chrono::seconds",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 5,
      "description": "ping frequency (seconds)"
    },
    {
      "name": "ws_max_subscriptions_per_stream",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 128,
      "description": "max symbols per connection (count)"
    },
    {
      "name": "ws_subscribe_depth_levels",
      "type": "uint32_t",
      "default": 20,
      "description": "depth levels (count)"
    },
    {
      "name": "ws_subscribe_depth_freq",
      "flag_name": "ws_subscribe_depth_freq_msecs",
      "type": "std::chrono::milliseconds",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 100,
      "description": "depth update frequency (milliseconds)"
    },
    {
      "name": "ws_subscribe_trade_details",
      "type": "bool",
      "default": false,
      "description": "report individual matches for trade summary? (bool)"
    },
    {
      "name": "encode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 1048576,
      "description": "encode buffer size"
    },
    {
      "name": "decode_buffer_size",
      "type": "uint32_t",
      "validator": "roq::core::flags::NonZero<uint32_t>",
      "default": 10485760,
      "description": "decode buffer size"
    }
