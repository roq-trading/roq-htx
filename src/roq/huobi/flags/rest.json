{
  "name": "roq/huobi/flags/REST",
  "type": "flags",
  "prefix": "rest_",
  "values": [
    {
      "name": "uri",
      "type": "roq/io/web/URI",
      "validator": "roq/core/flags/URI",
      "default": "https://api.huobi.pro",
      "description": "Exchange end-point"
    },
    {
      "name": "proxy",
      "type": "roq/io/web/URI",
      "validator": "roq/core/flags/URI",
      "description": "Proxy end-point"
    },
    {
      "name": "ping_freq",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5s",
      "description": "Ping frequency"
    },
    {
      "name": "ping_path",
      "type": "std/string",
      "validator": "roq/flags/validators/Path",
      "default": "/v1/common/timestamp",
      "description": "Ping path"
    },
    {
      "name": "request_timeout",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "30s",
      "description": "Request timeout"
    },
    {
      "name": "listen_key_refresh",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "1800s",
      "description": "Listen key refresh period"
    },
    {
      "name": "order_recv_window",
      "type": "std/nanoseconds",
      "validator": "roq/flags/validators/TimePeriod",
      "default": "5000ms",
      "description": "Receive window"
    },
    {
      "name": "cancel_on_disconnect",
      "type": "std/bool",
      "default": false,
      "description": "Cancel orders on disconnect?"
    }
  ]
}
